# ─────────────────────────────────────────────────────────────────────────────
# DocBot — Environment Variables Template
# Copy this file to .env and fill in your real values.
# NEVER commit .env — only commit this .env.example file.
# ─────────────────────────────────────────────────────────────────────────────

# ── LLM Provider Keys ────────────────────────────────────────────────────────

# Google Gemini (required for gemini-2.5-flash model)
# Get a free key at: https://aistudio.google.com/apikey
GEMINI_API_KEY=your_gemini_api_key_here

# GitHub Models (required for GPT-4.1 family)
# Create a token at: https://github.com/settings/tokens
GITHUB_TOKEN=your_github_token_here

# OpenAI Direct API (optional — only if not using GitHub Models)
OPENAI_API_KEY=your_openai_api_key_here

# ── App Configuration (optional overrides) ───────────────────────────────────

# Default model to use on startup (options: gemini-2.5-flash, gpt-4.1, gpt-4.1-mini, gpt-4.1-nano)
DEFAULT_MODEL=gemini-2.5-flash

# ── SECURITY CONFIGURATION (optional) ────────────────────────────────────────

# Email allowlist for public deployments (Streamlit Cloud)
# Format: comma-separated list of allowed emails
# When set, only users with these emails can access the app
# Example: SECRET_AUTH_EMAILS=user1@example.com,user2@example.com
# SECRET_AUTH_EMAILS=

# Database credentials for SQL pipeline (use READ-ONLY user for safety!)
# Example: postgresql://readonly_user:password@host:5432/database_name
# SQL_DATABASE_URL=
